[layer_names]

3d_render/layer_17="SimpleGrassTextured interactive layer"

[physics]

3d/physics_engine="Jolt Physics"
3d/default_gravity=24.5
3d/default_linear_damp=0.0
3d/default_angular_damp=0.005
3d/solver/solver_iterations=24

[rendering]

rendering_device/driver.windows="d3d12"
textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/size=8192
anti_aliasing/quality/screen_space_aa=2
lights_and_shadows/positional_shadow/atlas_size=8192

[shader_globals]

sgt_legacy_renderer={
"type": "int",
"value": 0
}
sgt_player_position={
"type": "vec3",
"value": Vector3(1000000, 1000000, 1000000)
}
sgt_player_mov={
"type": "vec3",
"value": Vector3(0, 0, 0)
}
sgt_normal_displacement={
"type": "sampler2D",
"value": "res://addons/simplegrasstextured/images/normal.png"
}
sgt_motion_texture={
"type": "sampler2D",
"value": "res://addons/simplegrasstextured/images/motion.png"
}
sgt_wind_direction={
"type": "vec3",
"value": Vector3(1, 0, 0)
}
sgt_wind_movement={
"type": "vec3",
"value": Vector2(0, 0)
}
sgt_wind_strength={
"type": "float",
"value": 0.15
}
sgt_wind_turbulence={
"type": "float",
"value": 1.0
}
sgt_wind_pattern={
"type": "sampler2D",
"value": "res://addons/simplegrasstextured/images/wind_pattern.png"
}

[steam]

initialization/app_data/app_id=480
initialization/processes/initialize_on_startup=true
initialization/processes/embed_callbacks=true
