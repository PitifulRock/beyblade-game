[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="gayblade"
run/main_scene="uid://b4agmgwf3aykh"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/bg_color=Color(0.09998604, 0.099985994, 0.09998598, 1)
boot_splash/show_image=false
config/icon="uid://83dpktcw2ew"
config/windows_native_icon="res://textures/bey_icon.ico"

[autoload]

Manager="*uid://bb6unaovyrdf1"
Master="*res://scripts/master.gd"
Registry="*res://beyblades/parts/part_registry.gd"
SimpleGrass="*res://addons/simplegrasstextured/singleton.tscn"
Console="*res://scripts/DebugConsole.tscn"
Effects="*res://scripts/effects_manager.tscn"
Settings="*res://scripts/settings_manager.gd"

[debug]

file_logging/enable_file_logging=true

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"

[editor_plugins]

enabled=PackedStringArray("res://addons/Quick-Add-Menu/plugin.cfg", "res://addons/anthonyec.camera_preview/plugin.cfg", "res://addons/simplegrasstextured/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")

